# LMS Ingestion Service Configuration

# Security
# Required for API access. Example: 'your-secure-api-key'
LMS_API_KEY=your-secure-api-key
DISABLE_AUTH=false

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 Configuration
S3_ASSETS_BUCKET=lms-course-assets
S3_CDN_BASE_URL=https://cdn.example.com

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=lms_db

# File Limits
MAX_UPLOAD_MB=500
MAX_EXTRACTED_GB=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
